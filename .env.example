DIRECTUS_URL=https://yourdirectus.api.site
DIRECTUS_TOKEN=your_admin_token

# Author details — these are public-facing but kept in env so the repo
# can serve as a template without exposing personal info in source code.
NEXT_PUBLIC_AUTHOR_NAME=Your Name
NEXT_PUBLIC_AUTHOR_TITLE=Software Engineer
NEXT_PUBLIC_AUTHOR_BIO=A short bio about yourself.
# AUTHOR_EMAIL is server-only; the email is never embedded in HTML or client JS.
# It is fetched on-demand via /api/email when a user clicks the reveal link.
AUTHOR_EMAIL=your@email.com
NEXT_PUBLIC_AUTHOR_AVATAR=https://example.com/avatar.png
NEXT_PUBLIC_AUTHOR_INITIALS=YN